@model mahadalzahrawebapi.Controllers.ReceiptModel

<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Receipt Template</title>
    <!-- Link to Bootstrap CSS for styling -->
    <link href="https://maxcdn.bootstrapcdn.com/bootstrap/4.5.2/css/bootstrap.min.css" rel="stylesheet">
    <style>
        /* Additional custom styles can be added here */
        body {
            width: 210mm;
            min-height: 297mm;
            margin: 10mm auto 30mm;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            color: #333;
            background-color: #f4f4f4;
            font-size: 17px;
            box-sizing: border-box;
        }

        /* Removing table borders */
        table {
            border-collapse: collapse;
        }

        table,
        th,
        td {
            border: none;
            /* Removes all borders */
        }
    </style>
</head>

<body>
    <div class="table table-responsive table-borderless" style="font-family: Garamond" id="printTable" class="d-none m-3">
        <div style="margin-left: 30px;" id="printOriginalTable">
            <div style="page-break-after: always;">
                <div style="height: 100px; "></div>
                <table style="width: 100%; height: 150px; font-size: 16px;">
                    <thead>
                    <th colspan="4" style="text-align: center; font-size: 18px;">
                        ONLINE RECEIPT<span style="float: right"> (Original)</span>
                    </th>
                    </thead>
                    <tbody>
                        <tr>
                            <td class="rcpt" style="width: 30%;padding-top: 1em; padding-bottom: 1em;">
                                Receipt No :
                                <strong>@Model.ReceiptNo</strong>
                            </td>
                            <td class="rcpt" style="width: 45%;padding-top: 1em; padding-bottom: 1em;"></td>
                            <td class="rcpt" style="width: 25%;padding-top: 1em; padding-bottom: 1em;">
                                Date : <strong>
                                    <span>@Model.Date</span>

                                </strong>
                            </td>
                        </tr>

                        <tr>
                            <td colspan="3" class="rcpt" style="padding-top: 1em; padding-bottom: 1em;">
                                Name :
                                <strong>@Model.Name (@Model.ItsId)</strong>
                            </td>
                        </tr>

                        <tr>
                            @if (Model.PaymentMode == "Cheque")
                            {
                            <td class="rcpt" style="width: 30%;padding-top: 1em; padding-bottom: 1em;">
                                <span>Payment Mode: </span><strong>@Model.PaymentMode</strong>
                            </td>
                            }
                            <td class="rcpt" style="width: 45%;padding-top: 1em; padding-bottom: 1em;">
                                Bank
                                Name : <strong>Razorpay PG</strong>
                            </td>
                        </tr>

                        <tr>
                            <td class="rcpt" style="width: 30%;padding-top: 1em; padding-bottom: 1em;">
                                Amount (INR) :
                                <strong>@Model.FeePaidAmount /-</strong>
                            </td>
                            <td class="rcpt" style="padding-top: 1em; padding-bottom: 1em;" colspan="2">
                                Amount in words
                                :
                                <strong>@Model.AmountInWord</strong>
                            </td>
                        </tr>

                        <tr>
                            <td class="rcpt" style="padding-top: 1em; padding-bottom: 1em;" colspan="3">
                                <strong>
                                    Voluntary
                                    contribution
                                </strong>
                            </td>
                        </tr>

                        <tr>
                            <td class="rcpt" style="padding-top: 1em; padding-bottom: 1em;" colspan="2">
                                Prepared By :
                                <b>@Model.PreparedBy</b>
                            </td>
                        </tr>

                        <tr>
                            <td class="rcpt" style="padding-top: 1em; padding-bottom: 1em;" colspan="4">
                                <p style="font-size: 11px; padding: 2px;">
                                    <span>*This is a system generated receipt and requires no signature.</span>
                                </p>
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
    <!-- Bootstrap and jQuery libraries -->
    <script src="https://ajax.googleapis.com/ajax/libs/jquery/3.5.1/jquery.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@4.5.2/dist/js/bootstrap.min.js"></script>
</body>

</html>